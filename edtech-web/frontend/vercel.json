{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/pages/(.*)", "destination": "/pages/$1" },
    { "source": "/google-callback", "destination": "/google-callback.html" },
    { "source": "/exam-list", "destination": "/exam-list.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/otp-verify", "destination": "/otp-verify.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/admin", "destination": "/pages/admin/login" },
    { "source": "/admin/login", "destination": "/pages/admin/login" },
    { "source": "/db-monitor", "destination": "/pages/admin/db-monitor" },
    { "source": "/db-monitor.html", "destination": "/pages/admin/db-monitor" },
    { "source": "/", "destination": "/index.html" }
  ]
}
